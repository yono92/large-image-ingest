{
  "name": "large-image-ingest",
  "version": "1.2.0",
  "description": "TypeScript-first ingestion toolkit for very large inspection images.",
  "type": "module",
  "license": "MIT",
  "packageManager": "npm@10.8.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yono92/large-image-ingest.git"
  },
  "bugs": {
    "url": "https://github.com/yono92/large-image-ingest/issues"
  },
  "homepage": "https://github.com/yono92/large-image-ingest#readme",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "sideEffects": false,
  "files": [
    "dist",
    "CHANGELOG.md",
    "docs",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    },
    "./core": {
      "types": "./dist/esm/core.d.ts",
      "import": "./dist/esm/core.js",
      "require": "./dist/cjs/core.js",
      "default": "./dist/esm/core.js"
    },
    "./transport-s3": {
      "types": "./dist/esm/s3.d.ts",
      "import": "./dist/esm/s3.js",
      "require": "./dist/cjs/s3.js",
      "default": "./dist/esm/s3.js"
    },
    "./transport-tus": {
      "types": "./dist/esm/tus.d.ts",
      "import": "./dist/esm/tus.js",
      "require": "./dist/cjs/tus.js",
      "default": "./dist/esm/tus.js"
    },
    "./node": {
      "types": "./dist/esm/node.d.ts",
      "import": "./dist/esm/node.js",
      "require": "./dist/cjs/node.js",
      "default": "./dist/esm/node.js"
    }
  },
  "types": "./dist/esm/index.d.ts",
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && node scripts/write-cjs-package.cjs && node scripts/verify-package-consumption.cjs",
    "clean": "node scripts/clean-dist.cjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run typecheck:examples && npm test && npm run build && npm audit --audit-level=moderate",
    "smoke:exports": "node scripts/verify-package-consumption.cjs",
    "test:integration": "node scripts/run-integration-tests.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.cjs.json --noEmit",
    "typecheck:examples": "tsc -p tsconfig.examples.json",
    "test": "vitest run"
  },
  "keywords": [
    "large-image",
    "image-upload",
    "resumable-upload",
    "chunk-upload",
    "inspection",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "typescript": "^5.0.0",
    "vitest": "^4.1.9"
  }
}
